<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane id="AnchorPane" style="-fx-background-color: #737373;" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="main.application.FXMLMenuCentralController">
    <children>
        <MenuBar AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <menus>
                <Menu fx:id="menuUsuarios" mnemonicParsing="false" text="Usuarios">
                    <items>
                        <MenuItem mnemonicParsing="false" onAction="#irRegistrarUsuarios" text="Registrar" />
                        <SeparatorMenuItem mnemonicParsing="false" />
                        <MenuItem mnemonicParsing="false" onAction="#irModificarUsuarios" text="Modificar" />
                        <SeparatorMenuItem mnemonicParsing="false" />
                        <MenuItem mnemonicParsing="false" onAction="#irMostrarUsuarios" text="Mostrar" />
                    </items>
                </Menu>

                <Menu fx:id="menuEmpleados" mnemonicParsing="false" text="Empleados">
                    <items>
                        <MenuItem mnemonicParsing="false" onAction="#irRegistrarEmpleados" text="Registrar" />
                        <SeparatorMenuItem mnemonicParsing="false" />
                        <MenuItem mnemonicParsing="false" onAction="#irModificarEmpleados" text="Modificar" />
                        <SeparatorMenuItem mnemonicParsing="false" />
                        <MenuItem mnemonicParsing="false" onAction="#irMostrarEmpleados" text="Mostrar" />
                    </items>
                </Menu>

                <Menu fx:id="menuDepartamentos" mnemonicParsing="false" text="Departamentos">
                    <items>
                        <MenuItem mnemonicParsing="false" onAction="#irModificarDepartamento" text="Asignar Encargado" />
                    </items>
                </Menu>

                <Menu fx:id="menuArticulos" mnemonicParsing="false" text="Artículos">
                    <items>
                        <MenuItem mnemonicParsing="false" onAction="#irGestionPartidas" text="Gestión de Partidas" />
                        <SeparatorMenuItem mnemonicParsing="false" />
                        <MenuItem mnemonicParsing="false" onAction="#irGestionArticulos" text="Catálogo de Artículos" />
                    </items>
                </Menu>

                <Menu mnemonicParsing="false" text="Logística">
                    <items>
                        <MenuItem fx:id="miCrearSolicitud" mnemonicParsing="false" onAction="#irCrearSolicitud" text="1. Crear Solicitud (Sucursal)" />
                        <MenuItem fx:id="miAprobarSalidas" mnemonicParsing="false" onAction="#irAprobarSalidas" text="2. Bandeja de Aprobación (Salidas)" />
                        <SeparatorMenuItem mnemonicParsing="false" />
                        <MenuItem fx:id="miRegistrarEntradas" mnemonicParsing="false" onAction="#irRegistrarEntradas" text="3. Registrar Facturas (Entradas)" />
                    </items>
                </Menu>
                <Menu mnemonicParsing="false" text="Reportes">
                    <MenuItem mnemonicParsing="false" onAction="#irCentralReportes" text="Central de Auditoría" />
                </Menu>
                <Menu mnemonicParsing="false" text="Ayuda" />
            </menus>
        </MenuBar>

        <AnchorPane fx:id="pane_Escritorio" layoutY="25.0" style="-fx-background-color: #737373;" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="25.0" />
    </children>
</AnchorPane>