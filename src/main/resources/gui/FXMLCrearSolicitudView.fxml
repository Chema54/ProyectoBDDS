<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="900.0" style="-fx-background-color: #737373;" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="main.application.FXMLCrearSolicitudController">
   <children>
      <VBox spacing="15.0" AnchorPane.bottomAnchor="15.0" AnchorPane.leftAnchor="15.0" AnchorPane.rightAnchor="15.0" AnchorPane.topAnchor="15.0">
         <children>
            <Label text="Generar Solicitud de Insumos (Carrito)" textFill="WHITE">
               <font><Font name="System Bold" size="24.0" /></font>
            </Label>
            
            <HBox spacing="15.0" alignment="CENTER_LEFT">
               <children>
                  <ComboBox fx:id="cbEmpleado" promptText="Solicitante..." prefWidth="250.0" />
                  <ComboBox fx:id="cbArticulo" promptText="Seleccionar Artículo..." prefWidth="250.0" />
                  <TextField fx:id="txtCantidad" promptText="Cantidad" prefWidth="100.0" />
               </children>
            </HBox>
            
            <HBox spacing="15.0" alignment="CENTER_LEFT">
                <children>
                    <TextField fx:id="txtUso" promptText="Justificación / Uso Destino" HBox.hgrow="ALWAYS" />
                    <Button mnemonicParsing="false" onAction="#btnAgregarPeticion" text="Enviar Petición a Almacén" style="-fx-background-color: #28c840; -fx-text-fill: white; -fx-font-weight: bold;"/>
                </children>
            </HBox>

            <TableView fx:id="tablaPendientes" VBox.vgrow="ALWAYS">
              <columns>
                <TableColumn fx:id="colEmpleado" prefWidth="200.0" text="Empleado Solicitante" />
                <TableColumn fx:id="colArticulo" prefWidth="200.0" text="Artículo" />
                <TableColumn fx:id="colCantidad" prefWidth="100.0" text="Cant. Pedida" />
                <TableColumn fx:id="colUso" prefWidth="300.0" text="Uso Destino" />
                <TableColumn fx:id="colFecha" prefWidth="100.0" text="Fecha" />
              </columns>
               <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
            </TableView>
         </children>
      </VBox>
   </children>
</AnchorPane>