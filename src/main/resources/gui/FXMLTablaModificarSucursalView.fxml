<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.image.*?>
<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane id="AnchorPane" prefHeight="691.0" prefWidth="1280.0" style="-fx-background-color: #737373;" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="main.application.FXMLTablaModificarSucursalController">
   <children>
      <VBox spacing="20.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <padding>
            <Insets bottom="30.0" left="50.0" right="50.0" top="30.0" />
         </padding>
         <children>
            <HBox alignment="CENTER_LEFT" spacing="20.0">
               <children>
                  <Label text="Administración de Sucursales" textFill="WHITE">
                     <font><Font name="System Bold" size="32.0" /></font>
                  </Label>
               </children>
            </HBox>
            
            <Label text="Nota: Haz doble clic sobre una sucursal para modificar sus datos." textFill="#dfdfdf">
               <font><Font name="System Italic" size="16.0" /></font>
            </Label>

            <TableView fx:id="tvSucursales" style="-fx-font-size: 16.0;" VBox.vgrow="ALWAYS">
              <columns>
                <TableColumn fx:id="tcNombre" prefWidth="400.0" text="Nombre" />
                  <TableColumn fx:id="tcDireccion" prefWidth="610.0" text="Dirección" />
              </columns>
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
            </TableView>
         </children>
      </VBox>
   </children>
</AnchorPane>
