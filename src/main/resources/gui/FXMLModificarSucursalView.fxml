<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.image.*?>
<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane id="AnchorPane" prefHeight="691.0" prefWidth="1280.0" style="-fx-background-color: #737373;" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="main.application.FXMLModificarSucursalController">
   <children>
      <GridPane hgap="10" vgap="10" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
        <columnConstraints>
            <ColumnConstraints hgrow="ALWAYS" minWidth="10.0" prefWidth="100.0" />
          <ColumnConstraints hgrow="ALWAYS" minWidth="10.0" prefWidth="100.0" />
            <ColumnConstraints hgrow="ALWAYS" minWidth="10.0" prefWidth="100.0" />
            <ColumnConstraints hgrow="ALWAYS" minWidth="10.0" prefWidth="100.0" />
        </columnConstraints>
        <rowConstraints>
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="ALWAYS" />
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="ALWAYS" />
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="ALWAYS" />
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="ALWAYS" />
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="ALWAYS" />
        </rowConstraints>
         <children>

            <Label text="Nombre" textFill="WHITE" GridPane.rowIndex="2">
               <font><Font size="26.0" /></font><GridPane.margin><Insets left="50.0" /></GridPane.margin>
            </Label>
            <TextField fx:id="tfNombreSucursal" promptText="Ej: Global Finance Plaza Arco Sur" GridPane.columnIndex="1" GridPane.columnSpan="2" GridPane.rowIndex="2">
               <font><Font size="18.0" /></font><GridPane.margin><Insets right="20.0" /></GridPane.margin>
            </TextField>

            <Label text="Dirección" textFill="WHITE" GridPane.rowIndex="3">
               <font><Font size="26.0" /></font><GridPane.margin><Insets left="50.0" /></GridPane.margin>
            </Label>
            <TextField fx:id="tfDireccionSucursal" promptText="Ej: Arco Sur 83, Campo Nuevo..." GridPane.columnIndex="1" GridPane.columnSpan="3" GridPane.rowIndex="3">
               <font><Font size="18.0" /></font><GridPane.margin><Insets right="50.0" /></GridPane.margin>
            </TextField>

            <Button mnemonicParsing="false" onAction="#btnGuardar" prefHeight="50.0" prefWidth="200.0" style="-fx-background-color: #156600;" text="Guardar Cambios" textFill="WHITE" GridPane.columnIndex="3" GridPane.rowIndex="4" />
         </children>
      </GridPane>
   </children>
</AnchorPane>
