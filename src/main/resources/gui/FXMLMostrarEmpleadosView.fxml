<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="1000.0" style="-fx-background-color: #737373;" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="main.application.FXMLMostrarEmpleadosController">
   <children>
      <VBox spacing="15.0" AnchorPane.bottomAnchor="15.0" AnchorPane.leftAnchor="15.0" AnchorPane.rightAnchor="15.0" AnchorPane.topAnchor="15.0">
         <children>
            <Label text="Directorio de Empleados" textFill="WHITE">
               <font>
                  <Font name="System Bold" size="24.0" />
               </font>
            </Label>
            
            <HBox alignment="CENTER_LEFT" spacing="15.0">
               <children>
                  <Label text="Filtrar por Sucursal:" textFill="WHITE">
                     <font><Font size="16.0" /></font>
                  </Label>
                  <ComboBox fx:id="cbSucursalFiltro" prefWidth="250.0" promptText="Todas las sucursales..." />
                  <Button mnemonicParsing="false" onAction="#btnLimpiarFiltro" text="Limpiar Filtro" />
               </children>
            </HBox>
            
            <TableView fx:id="tablaEmpleados" VBox.vgrow="ALWAYS">
              <columns>
                <TableColumn fx:id="colId" prefWidth="50.0" text="ID" />
                <TableColumn fx:id="colNombre" prefWidth="120.0" text="Nombre" />
                <TableColumn fx:id="colApellidos" prefWidth="150.0" text="Apellidos" />
                <TableColumn fx:id="colDepartamento" prefWidth="150.0" text="Departamento" />
                <TableColumn fx:id="colIdSucursal" prefWidth="80.0" text="ID Suc" />
                <TableColumn fx:id="colSucursal" prefWidth="150.0" text="Sucursal" />
                <TableColumn fx:id="colUsuario" prefWidth="120.0" text="Usuario" />
              </columns>
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
            </TableView>
         </children>
      </VBox>
   </children>
</AnchorPane>