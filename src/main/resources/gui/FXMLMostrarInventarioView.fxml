<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="900.0" style="-fx-background-color: #737373;" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="main.application.FXMLMostrarInventarioController">
   <children>
      <VBox spacing="15.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="30.0" AnchorPane.rightAnchor="30.0" AnchorPane.topAnchor="20.0">
         <children>
            <Label text="Inventario Físico (Stock)" textFill="WHITE">
               <font><Font name="System Bold" size="24.0" /></font>
            </Label>
            
            <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-background-color: #555555; -fx-padding: 10;">
               <children>
                  <Label text="Buscar Artículo:" textFill="WHITE"><font><Font size="16.0" /></font></Label>
                  <TextField fx:id="txtBuscar" promptText="Escribe el nombre..." prefWidth="300.0" />
                  <Button mnemonicParsing="false" onAction="#btnBuscar" text="Buscar Rápido" style="-fx-background-color: #007bff; -fx-text-fill: white; -fx-font-weight: bold;"/>
                  <Button mnemonicParsing="false" onAction="#btnLimpiar" text="Limpiar" style="-fx-background-color: #6c757d; -fx-text-fill: white;"/>
                  
                  <Pane HBox.hgrow="ALWAYS" />
                  
                  <Button mnemonicParsing="false" onAction="#btnFiltroFaltantes" text="Ver &lt; Mínimo" style="-fx-background-color: #ff5f56; -fx-text-fill: white; -fx-font-weight: bold;">
                     <tooltip>
                        <Tooltip text="Mostrar artículos por debajo del stock mínimo" />
                     </tooltip>
                  </Button>
                  <Button mnemonicParsing="false" onAction="#btnFiltroExcedentes" text="Ver &gt; Máximo" style="-fx-background-color: #ffb84d; -fx-text-fill: white; -fx-font-weight: bold;">
                     <tooltip>
                        <Tooltip text="Mostrar artículos por encima del stock máximo" />
                     </tooltip>
                  </Button>
               </children>
            </HBox>

            <TableView fx:id="tablaInventario" VBox.vgrow="ALWAYS">
              <columns>
                <TableColumn fx:id="colSucursal" prefWidth="100.0" text="ID Sucursal" />
                <TableColumn fx:id="colArticulo" prefWidth="350.0" text="Nombre del Artículo" />
                <TableColumn fx:id="colStock" prefWidth="120.0" text="Stock Actual" />
                <TableColumn fx:id="colMinimo" prefWidth="120.0" text="Stock Mínimo" />
                <TableColumn fx:id="colMaximo" prefWidth="120.0" text="Stock Máximo" />
              </columns>
            </TableView>
         </children>
      </VBox>
   </children>
</AnchorPane>